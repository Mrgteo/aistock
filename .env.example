# 股票交易辅助系统配置文件

# ========== 应用配置 ==========
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ========== JWT认证配置 ==========
JWT_SECRET=stock-trade-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ========== DeepSeek API配置 ==========
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEFAULT_MODEL_NAME=deepseek-chat

# ========== CORS配置 ==========
ALLOWED_ORIGINS=["*"]
